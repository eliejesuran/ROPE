# EuroMsg Backend - Environment Variables
# Copy to .env and fill in your values

# Server
PORT=3000
NODE_ENV=development

# PostgreSQL (EU-hosted, e.g. Hetzner Finland)
DATABASE_URL=postgresql://euromsg_user:CHANGE_ME@localhost:5432/euromsg_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING_MIN_64_CHARS
JWT_EXPIRES_IN=30d

# OTP (Sprint 1: hardcoded for dev, Sprint 2: Infobip)
OTP_BYPASS_CODE=123456
OTP_BYPASS_ENABLED=true

# SMS Provider (Sprint 2 - Infobip, EU-based, GDPR compliant)
# INFOBIP_API_KEY=
# INFOBIP_BASE_URL=

# Encryption
# AES-256 key derivation - server-side pepper for key IDs only
# (Messages are E2E encrypted, server never sees content)
SERVER_PEPPER=CHANGE_ME_TO_ANOTHER_LONG_RANDOM_STRING
